EXPO_PUBLIC_API_URL="http://localhost:3812"

# Sentry — crash reporting (frontend).
# Get DSN from https://sentry.io → Project Settings → Client Keys (DSN).
# Leave blank to disable; the SDK no-ops gracefully without a key.
EXPO_PUBLIC_SENTRY_DSN=""

# Surfaced as `release` in Sentry events. Recommended: bump on every prod
# build (sync with package.json `version`).
EXPO_PUBLIC_APP_VERSION="1.0.0"

# PostHog — product analytics (frontend).
# Get key from https://eu.posthog.com → Project Settings → Project API Key.
# Leave blank to disable; analytics calls become no-ops.
EXPO_PUBLIC_POSTHOG_KEY=""
# Override only if you self-host. Default is EU cloud (РФ data residency).
EXPO_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
