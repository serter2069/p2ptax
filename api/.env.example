DATABASE_URL="postgresql://user:password@localhost:5432/p2ptax"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-in-production-refresh"
PORT=3812
MINIO_ENDPOINT="localhost"
MINIO_PORT=9000
MINIO_ACCESS_KEY="minioadmin"
MINIO_SECRET_KEY="minioadmin"
MINIO_BUCKET="p2ptax"

# Sentry — error reporting (backend).
# Get DSN from https://sentry.io → Project Settings → Client Keys (DSN).
# Leave blank in dev; the SDK no-ops gracefully without a key.
SENTRY_DSN=""
# Optional: tag events with a release identifier (e.g. git SHA).
SENTRY_RELEASE=""

# ЮKassa — VIP wallet top-up.
# Get test creds at https://yookassa.ru → "Интеграция" → "Ключи API".
YK_SHOP_ID=
YK_SECRET_KEY=
YK_RETURN_URL_BASE=https://your-public-url
