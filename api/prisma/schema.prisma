generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  GUEST
  USER
  ADMIN
}

enum RequestStatus {
  ACTIVE
  CLOSING_SOON
  CLOSED
}

model User {
  id                           String    @id @default(uuid())
  email                        String    @unique
  role                         Role?
  // Iter11 — specialist opt-in flag (replaces role = SPECIALIST).
  isSpecialist                 Boolean   @default(false) @map("is_specialist")
  // Timestamp when specialist onboarding fully completed (profile populated).
  // Null = either not a specialist, or specialist onboarding in progress.
  specialistProfileCompletedAt DateTime? @map("specialist_profile_completed_at")
  firstName                    String?   @map("first_name")
  lastName                     String?   @map("last_name")
  avatarUrl                    String?   @map("avatar_url")
  isAvailable                  Boolean   @default(false) @map("is_available")
  isBanned                     Boolean   @default(false) @map("is_banned")
  // Iter13 — specialist catalog visibility. When true, appears in public catalog.
  // Default false; specialist opts in during onboarding or via settings.
  isPublicProfile              Boolean   @default(false) @map("is_public_profile")
  // Soft-delete timestamp. When non-null the user is considered deleted —
  // PII is anonymized in-place and they're hidden from public catalog/queries
  // but the row is preserved so threads/messages keep a valid FK target.
  deletedAt                    DateTime? @map("deleted_at")
  lastSeenAt                   DateTime? @map("last_seen_at")
  // ЮKassa saved payment-method id ("token" of the card). Captured on
  // the first VIP activation when ЮKassa returns the bound method via
  // webhook. Subsequent daily charges use this id directly via the
  // recurring-payments API (no 3DS, no user interaction). Null = no
  // card on file → VIP toggle redirects to ЮKassa hosted checkout.
  yookassaPaymentMethodId      String?   @map("yookassa_payment_method_id")
  // Human-readable card label like "Visa *4242" so the FE can show
  // which card is bound without storing PAN. Captured from the same
  // webhook payload as the id.
  yookassaPaymentMethodTitle   String?   @map("yookassa_payment_method_title")
  // Set by the daily cron when an autopay charge fails (card declined,
  // expired, blocked). When non-null, FE shows a "Платёж не прошёл,
  // обновите карту" banner. Cleared on successful re-bind.
  lastChargeFailedAt           DateTime? @map("last_charge_failed_at")
  // Active PRO plan. Pricing model: per-account, fixed monthly fee,
  // limited number of VIP FNS slots. Null = no plan (specialist
  // gets only the regular 5-min-delayed notifications). Daily cron
  // charges plan.monthlyPriceKopeks / 30 once per user.
  subscriptionPlanId           String?   @map("subscription_plan_id")
  subscriptionPlan             SubscriptionPlan? @relation(fields: [subscriptionPlanId], references: [id], onDelete: SetNull)
  // When the current plan was activated. Used for the "тариф с ..."
  // line on the PRO tab. Cleared along with subscriptionPlanId on
  // failed-charge or explicit cancel.
  subscriptionStartedAt        DateTime? @map("subscription_started_at")
  // Когда списываем PRO в следующий раз. Выставляется при первом
  // платеже (startedAt + 30 дней) и сдвигается +30 дней после
  // каждого успешного автосписания. NULL = подписки нет.
  subscriptionNextChargeAt     DateTime? @map("subscription_next_charge_at")
  createdAt                    DateTime  @default(now()) @map("created_at")
  updatedAt                    DateTime  @updatedAt @map("updated_at")

  specialistProfile       SpecialistProfile?
  specialistFns           SpecialistFns[]
  specialistServices      SpecialistService[]
  specialistCases         SpecialistCase[]
  specialistReviews       SpecialistReview[]
  fnsStaffReviews         FnsStaffReview[]
  requests                Request[]
  clientThreads           Thread[]                 @relation("ClientThreads")
  specialistThreads       Thread[]                 @relation("SpecialistThreads")
  messages                Message[]
  refreshTokens           RefreshToken[]
  sessions                Session[]
  contactViewsAsOwner     ContactView[]            @relation("ContactViewOwner")
  contactViewsAsViewer    ContactView[]            @relation("ContactViewViewer")
  notifications           Notification[]
  notificationPreferences NotificationPreference[]
  complaintsReported      Complaint[]              @relation("ComplaintReporter")
  complaintsReceived      Complaint[]              @relation("ComplaintTarget")
  savedSpecialists        SavedSpecialist[]        @relation("SavedByUser_user")
  savedByUsers            SavedSpecialist[]        @relation("SavedByUser_specialist")
  vipFns                  SpecialistVipFns[]
  billingTxs              BillingTx[]

  @@map("users")
}

model SpecialistProfile {
  id                String  @id @default(uuid())
  userId            String  @unique @map("user_id")
  description       String?
  phone             String?
  telegram          String?
  whatsapp          String?
  officeAddress     String? @map("office_address")
  workingHours      String? @map("working_hours")
  // Iteration 5 — credibility stack fields
  exFnsStartYear    Int?    @map("ex_fns_start_year")
  exFnsEndYear      Int?    @map("ex_fns_end_year")
  exFnsOffice       String? @map("ex_fns_office")
  verifiedExFns     Boolean @default(false) @map("verified_ex_fns")
  yearsOfExperience Int?    @map("years_of_experience")
  // Long-form free-text fields surfaced under the specialist's name on
  // the public profile detail. yearsOfExperience above stays for back-
  // compat (some seed data uses it); the user-editable surface in
  // settings now writes prose into these columns.
  experienceText    String?  @map("experience_text")
  specializationText String? @map("specialization_text")
  specializations   Json? // array of strings (legacy seed data)
  certifications    Json? // array of strings
  // Cached median response time (minutes) — backfilled by recompute-response-times.ts cron.
  // Falls back to live computation when null and >=5 closed threads exist.
  cachedAvgResponseMinutes Int? @map("cached_avg_response_minutes")

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  contactMethods ContactMethod[]

  @@map("specialist_profiles")
}

model SpecialistCase {
  id             String   @id @default(uuid())
  specialistId   String   @map("specialist_id")
  title          String
  category       String // "Выездная проверка" | "Камеральная проверка" | "115-ФЗ" | "ОКК"
  amount         Int? // в рублях (доначисления)
  resolvedAmount Int?     @map("resolved_amount") // в рублях (оспорено)
  days           Int? // срок решения
  status         String // "resolved" | "in_progress"
  description    String
  year           Int?
  order          Int      @default(0)
  createdAt      DateTime @default(now()) @map("created_at")

  specialist User @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  @@index([specialistId])
  @@map("specialist_cases")
}

model SpecialistReview {
  id            String   @id @default(uuid())
  specialistId  String   @map("specialist_id")
  authorName    String   @map("author_name")
  rating        Int // 1..5
  date          DateTime
  text          String
  categoryChips Json?    @map("category_chips") // array of strings
  createdAt     DateTime @default(now()) @map("created_at")

  specialist User @relation(fields: [specialistId], references: [id], onDelete: Cascade)

  @@index([specialistId])
  @@map("specialist_reviews")
}

model ContactMethod {
  id        String   @id @default(uuid())
  profileId String   @map("profile_id")
  type      String // phone | email | telegram | whatsapp | max | vk | website
  value     String
  label     String?
  order     Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  profile SpecialistProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@map("contact_methods")
}

model SpecialistFns {
  id           String @id @default(uuid())
  specialistId String @map("specialist_id")
  fnsId        String @map("fns_id")

  specialist User      @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  fns        FnsOffice @relation(fields: [fnsId], references: [id], onDelete: Cascade)

  services SpecialistService[]

  @@unique([specialistId, fnsId])
  @@map("specialist_fns")
}

model SpecialistService {
  id              String @id @default(uuid())
  specialistId    String @map("specialist_id")
  fnsId           String @map("fns_id")
  serviceId       String @map("service_id")
  specialistFnsId String @map("specialist_fns_id")

  specialist    User          @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  fns           FnsOffice     @relation(fields: [fnsId], references: [id], onDelete: Cascade)
  service       Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  specialistFns SpecialistFns @relation(fields: [specialistFnsId], references: [id], onDelete: Cascade)

  @@unique([specialistId, fnsId, serviceId])
  @@map("specialist_services")
}

model City {
  id   String @id @default(uuid())
  name String
  slug String @unique

  fnsOffices FnsOffice[]
  requests   Request[]

  @@map("cities")
}

model FnsOffice {
  id            String  @id @default(uuid())
  cityId        String  @map("city_id")
  name          String
  code          String  @unique
  address       String?
  searchAliases String? @map("search_aliases")
  // Free-text description shown on the public /fns/[id] page.
  // Currently unmanaged — admins will populate via a future admin UI.
  description   String?
  // Monthly VIP price in kopeks for instant-notification access on
  // this FNS. NULL = VIP not offered for this office (specialists
  // can't subscribe). Daily charge = vipMonthlyPriceKopeks / 30.
  vipMonthlyPriceKopeks Int? @map("vip_monthly_price_kopeks")

  // Координаты для Я.Карт. Заполняются скриптом prisma/yandex-geocode.ts
  // через HTTP Геокодер (geocode-maps.yandex.ru). geocodedAt — когда
  // последний раз обновляли (для «протухания» данных).
  latitude    Float?   @map("latitude")
  longitude   Float?   @map("longitude")
  geocodedAt  DateTime? @map("geocoded_at")

  // Я.Карты Геопоиск (рейтинг/отзывы/orgId) — заполняются позже,
  // когда подключим Search API. Все поля nullable, чтобы не ломать
  // имеющиеся записи.
  yandexOrgId        String?  @map("yandex_org_id")
  yandexOrgUrl       String?  @map("yandex_org_url")
  yandexRating       Float?   @map("yandex_rating")
  yandexReviewsCount Int?     @map("yandex_reviews_count")
  yandexUpdatedAt    DateTime? @map("yandex_updated_at")

  // Контакты и метаданные ИФНС (Dadata где есть + рыба-fallback).
  inn               String? // ИНН инспекции (как ЮЛ)
  kpp               String? // КПП
  oktmo             String? // ОКТМО
  officialPhone     String? @map("official_phone")
  officialEmail     String? @map("official_email")
  officialWebsite   String? @map("official_website")
  workingHours      String? @map("working_hours") // человекочитаемое расписание

  // Фото ИФНС с nalog.gov.ru (фасад, оперзал и т.п.) и URL первоисточника.
  photoUrls    String[] @default([]) @map("photo_urls")
  nalogGovUrl  String?  @map("nalog_gov_url")

  city               City                @relation(fields: [cityId], references: [id], onDelete: Cascade)
  specialistFns      SpecialistFns[]
  specialistServices SpecialistService[]
  requests           Request[]
  vipSubscribers     SpecialistVipFns[]
  reviews            FnsReview[]
  staff              FnsStaff[]

  @@map("fns_offices")
}

// Сотрудники ИФНС — заглушка-каталог для верстки и согласования с
// заказчиком. Реальные данные подъедут позже (либо ручной ввод
// админом, либо парсинг public-страниц nalog.gov.ru). source
// различает мок от реального для последующей чистки.
model FnsStaff {
  id         String  @id @default(uuid())
  fnsId      String  @map("fns_id")
  firstName  String  @map("first_name")
  lastName   String  @map("last_name")
  middleName String? @map("middle_name")
  position   String  // "Начальник инспекции", "Зам. начальника" и т.п.
  department String? // "Отдел камеральных проверок"
  phone      String? // "+7 (3902) 24-66-56" или null
  email      String?
  photoUrl   String? @map("photo_url")
  sortOrder  Int     @default(0) @map("sort_order")
  source     String  @default("seed") // seed | manual | imported

  // Кэшированные агрегаты по отзывам — обновляются при каждом
  // создании/удалении отзыва. Дешевле, чем считать на лету.
  cachedAvgRating    Float?  @map("cached_avg_rating")
  cachedReviewsCount Int     @default(0) @map("cached_reviews_count")

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  fns     FnsOffice        @relation(fields: [fnsId], references: [id], onDelete: Cascade)
  reviews FnsStaffReview[]

  @@index([fnsId])
  @@map("fns_staff")
}

// Отзыв на сотрудника ИФНС. Авторизованные пользователи (userId)
// и сид/импорт (userId=null) пишут сюда напрямую. Рейтинг 1-5.
model FnsStaffReview {
  id         String   @id @default(uuid())
  staffId    String   @map("staff_id")
  userId     String?  @map("user_id")
  authorName String   @map("author_name")
  rating     Int      // 1..5
  text       String
  source     String   @default("user") // user | seed | imported
  createdAt  DateTime @default(now()) @map("created_at")

  staff FnsStaff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  user  User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([staffId])
  @@index([userId])
  @@map("fns_staff_reviews")
}

// Отзывы про ИФНС. Пока что наполняются сидом из заготовленных
// «как будто из Я.Карт» отзывов — для верстки и SEO. После
// подключения Геопоиска (или своего флоу отзывов от пользователей
// платформы) сюда будут писаться реальные данные. source говорит,
// откуда отзыв пришёл.
model FnsReview {
  id         String   @id @default(uuid())
  fnsId      String   @map("fns_id")
  authorName String   @map("author_name")
  rating     Int      // 1..5
  text       String
  source     String   @default("yandex_maps") // yandex_maps | platform | imported
  reviewDate DateTime @map("review_date")
  createdAt  DateTime @default(now()) @map("created_at")

  fns FnsOffice @relation(fields: [fnsId], references: [id], onDelete: Cascade)

  @@index([fnsId])
  @@map("fns_reviews")
}

// PRO plan tier — three of these are seeded (Lite/Pro/Premium) and
// editable by admins on /admin/plans. Each plan has a fixed monthly
// price and a max number of FNS slots a specialist can flip into
// VIP at once. Daily cron charges plan.monthlyPriceKopeks / 30.
//
// Adding ИФНС to the VIP list is free within the limit; switching
// plans only changes the daily charge rate (and may require trim
// when downgrading to a smaller limit).
model SubscriptionPlan {
  id                 String   @id @default(uuid())
  // Stable slug for code paths that key off plan kind (e.g. analytics
  // tags). UI uses `name`. Codes seeded as 'lite' | 'pro' | 'premium'
  // but admins can introduce new ones.
  code               String   @unique
  name               String
  monthlyPriceKopeks Int      @map("monthly_price_kopeks")
  // Max number of SpecialistVipFns rows a user on this plan may have.
  fnsLimit           Int      @map("fns_limit")
  // Display order on the upsell screen (ascending). Inactive plans
  // are hidden from new sign-ups but kept for users already on them.
  sortOrder          Int      @default(0) @map("sort_order")
  isActive           Boolean  @default(true) @map("is_active")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  users              User[]

  @@map("subscription_plans")
}

// Per-FNS VIP toggle for a specialist. Existence of a row = VIP is
// active for (specialistId, fnsId) RIGHT NOW. The daily cron reads
// this table to compute today's autopay total and wipes ALL rows
// for a user when the autopay charge is rejected.
model SpecialistVipFns {
  id           String   @id @default(uuid())
  specialistId String   @map("specialist_id")
  fnsId        String   @map("fns_id")
  // Most recent moment this row was created or re-activated. Used by
  // the daily charge cron as the "since when" reference and shown in
  // the billing UI ("Активна с …").
  activatedAt  DateTime @default(now()) @map("activated_at")

  specialist User      @relation(fields: [specialistId], references: [id], onDelete: Cascade)
  fns        FnsOffice @relation(fields: [fnsId], references: [id], onDelete: Cascade)

  @@unique([specialistId, fnsId])
  @@index([fnsId])
  @@map("specialist_vip_fns")
}

// Append-only ledger of every ЮKassa interaction.
//   - 'bind_first_charge' — first VIP-FNS activation: card was bound
//     and the first day pre-paid in one shot.
//   - 'daily_charge' — autopay deduction by the daily cron.
//   - 'charge_failed' — autopay attempt rejected by ЮKassa
//     (declined, expired, blocked). The cron also wipes the
//     SpecialistVipFns rows for that user when this happens.
//   - 'vip_deactivated' — explicit deactivation marker (manual
//     unbind, all-fail rollback).
model BillingTx {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  // Negative = debit (charge). Stored in kopeks to avoid float math.
  // 'charge_failed' rows record the attempted amount as negative too,
  // so a quick sum can't accidentally count a failure as paid.
  amountKopeks  Int      @map("amount_kopeks")
  kind          String
  // Optional FNS reference — set on daily_charge / bind_first_charge.
  fnsId         String?  @map("fns_id")
  // ЮKassa payment id, the source of truth for de-dupe.
  externalRef   String?  @map("external_ref")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("billing_tx")
}

model Service {
  id   String @id @default(uuid())
  name String @unique

  specialistServices SpecialistService[]
  requests           Request[]

  @@map("services")
}

model Request {
  id              String        @id @default(uuid())
  userId          String        @map("user_id")
  title           String
  cityId          String        @map("city_id")
  fnsId           String        @map("fns_id")
  serviceId       String?       @map("service_id")
  description     String
  status          RequestStatus @default(ACTIVE)
  isPublic        Boolean       @default(true) @map("is_public")
  lastActivityAt  DateTime      @default(now()) @map("last_activity_at")
  extensionsCount Int           @default(0) @map("extensions_count")
  createdAt       DateTime      @default(now()) @map("created_at")

  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  city    City      @relation(fields: [cityId], references: [id])
  fns     FnsOffice @relation(fields: [fnsId], references: [id])
  service Service?  @relation(fields: [serviceId], references: [id])
  threads Thread[]
  files   File[]

  @@index([userId, status, createdAt])
  @@map("requests")
}

model Thread {
  id                   String    @id @default(uuid())
  requestId            String?   @map("request_id")
  clientId             String    @map("client_id")
  specialistId         String    @map("specialist_id")
  lastMessageAt        DateTime? @map("last_message_at")
  clientLastReadAt     DateTime? @map("client_last_read_at")
  specialistLastReadAt DateTime? @map("specialist_last_read_at")
  createdAt            DateTime  @default(now()) @map("created_at")
  deletedAt            DateTime? @map("deleted_at")
  deletedBy            String?   @map("deleted_by")

  request    Request?  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  client     User      @relation("ClientThreads", fields: [clientId], references: [id])
  specialist User      @relation("SpecialistThreads", fields: [specialistId], references: [id])
  messages   Message[]

  @@unique([requestId, specialistId])
  @@index([specialistId, createdAt])
  @@index([clientId, createdAt])
  @@map("threads")
}

model Message {
  id        String   @id @default(uuid())
  threadId  String   @map("thread_id")
  senderId  String   @map("sender_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User   @relation(fields: [senderId], references: [id])

  @@index([threadId, createdAt])
  @@index([threadId, senderId])
  @@map("messages")
}

model File {
  id         String   @id @default(uuid())
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  url        String
  // Optional small WebP preview generated server-side at upload time.
  // Lets a 200×200 chat-bubble slot avoid pulling a multi-MB original
  // through the wire. Older rows (uploaded before thumbnails existed)
  // keep this null and fall back to `url`.
  thumbUrl   String?  @map("thumb_url")
  filename   String
  size       Int
  mimeType   String   @map("mime_type")
  createdAt  DateTime @default(now()) @map("created_at")

  // Optional FK to request (for request attachments)
  requestId String?  @map("request_id")
  request   Request? @relation(fields: [requestId], references: [id], onDelete: SetNull)

  // Anonymous upload tracking — when an unauthenticated visitor attaches
  // files before submitting a request, the rows carry a session id and an
  // expiry timestamp. On successful request creation the session id is
  // cleared and the row is bound to the new requestId. A periodic cleanup
  // job removes rows where requestId IS NULL AND expiresAt < now().
  sessionId String?   @map("session_id")
  expiresAt DateTime? @map("expires_at")

  @@index([entityType, entityId])
  @@index([sessionId])
  @@index([expiresAt])
  @@map("files")
}

model Setting {
  key   String @id
  value String

  @@map("settings")
}

model OtpCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@index([email, expiresAt])
  @@map("otp_codes")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// Wave 7: per-login session record. One row per OTP verification, with
// ip + userAgent captured at login. lastSeenAt is bumped on each
// successful /refresh so admins can see active vs idle sessions.
// Doesn't replace RefreshToken (which the auth flow needs as a primary
// key for rotation) — it's a separate analytics-grade log.
model Session {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("sessions")
}

// Wave 7: 'Показать контакты' click event. Owner-side analytics so
// specialists can see who looked at their contacts (and admins can
// audit suspicious viewer patterns later).
model ContactView {
  id              String   @id @default(uuid())
  // Profile being viewed (owner of the contacts) — always a
  // specialist's userId.
  ownerId         String   @map("owner_id")
  // Caller who clicked 'Показать контакты'. Null for anon viewers
  // (we let signed-in users skip the button, so anon stays gated by
  // the existing 'войдите чтобы увидеть' UI).
  viewerId        String?  @map("viewer_id")
  ip              String?
  userAgent       String?  @map("user_agent")
  createdAt       DateTime @default(now()) @map("created_at")

  owner  User  @relation("ContactViewOwner",  fields: [ownerId],  references: [id], onDelete: Cascade)
  viewer User? @relation("ContactViewViewer", fields: [viewerId], references: [id], onDelete: SetNull)

  @@index([ownerId, createdAt])
  @@index([viewerId, createdAt])
  @@map("contact_views")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String // new_response | new_message | new_request_in_city | promo_expiring
  title     String
  body      String
  entityId  String?  @map("entity_id") // requestId or threadId
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  deliveryLogs NotificationDeliveryLog[]

  @@index([userId, isRead, createdAt])
  @@map("notifications")
}

model NotificationPreference {
  id        String  @id @default(uuid())
  userId    String  @map("user_id")
  eventType String  @map("event_type") // new_response | new_message | new_request_in_city | promo_expiring
  email     Boolean @default(true)
  inApp     Boolean @default(true) @map("in_app")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, eventType])
  @@map("notification_preferences")
}

model NotificationDeliveryLog {
  id             String   @id @default(uuid())
  notificationId String?  @map("notification_id")
  channel        String // email | inapp
  status         String // sent | skipped | failed
  reason         String?
  createdAt      DateTime @default(now()) @map("created_at")

  notification Notification? @relation(fields: [notificationId], references: [id], onDelete: SetNull)

  @@map("notification_delivery_logs")
}

enum ComplaintStatus {
  NEW
  REVIEWED
}

model Complaint {
  id           String          @id @default(uuid())
  reporterId   String          @map("reporter_id")
  targetUserId String          @map("target_user_id")
  text         String
  status       ComplaintStatus @default(NEW)
  createdAt    DateTime        @default(now()) @map("created_at")
  reviewedAt   DateTime?       @map("reviewed_at")

  reporter   User @relation("ComplaintReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser User @relation("ComplaintTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@map("complaints")
}

model SavedSpecialist {
  id           String   @id @default(cuid())
  userId       String
  specialistId String
  savedAt      DateTime @default(now())
  user         User     @relation("SavedByUser_user", fields: [userId], references: [id], onDelete: Cascade)
  specialist   User     @relation("SavedByUser_specialist", fields: [specialistId], references: [id], onDelete: Cascade)

  @@unique([userId, specialistId])
  @@map("saved_specialists")
}
